# ===== MasterPag (PayGateway) =====
# Pegue em: Configurações → Chaves API.
# ⚠️ Rotacione a chave que foi exposta no chat ANTES de usar.
# Use pk_test_/sk_test_ para testar; pk_live_/sk_live_ só em produção.
MASTERPAG_PUBLIC_KEY=pk_test_xxxxxxxx
MASTERPAG_SECRET_KEY=sk_test_xxxxxxxx

# (Opcional) Segredo para validar a assinatura HMAC dos webhooks.
MASTERPAG_WEBHOOK_SECRET=

# (Opcional) URL pública do webhook (ex.: https://SEU-SITE.vercel.app/api/webhook)
MASTERPAG_WEBHOOK_URL=

# (Opcional) Só mude se a MasterPag indicar outra base:
# MASTERPAG_BASE_URL=https://api.masterpag.com/functions/v1

# (Opcional) Se hospedar o frontend em outro domínio, restrinja o CORS:
# CORS_ORIGIN=https://seusite.com
